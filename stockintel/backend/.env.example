# ---------------------------------------------------------------------------
# StockIntel backend configuration — TEMPLATE
#
# Copy to `.env` and fill in your keys there. This file is committed to the
# repository, so it must never contain real credentials; `.env` is gitignored
# and is the only place secrets belong.
#
# The application runs WITHOUT any of these keys: market data (yfinance) and
# sentiment (FinBERT, local) need no credentials. Features whose key is missing
# report an explicit "NOT CONFIGURED" state in the UI, with setup instructions —
# they never fall back to fabricated data.
# ---------------------------------------------------------------------------

# --- News provider ---------------------------------------------------------
# Required for: News & Current Affairs, news sentiment, event-impact analysis.
# Marketaux tags articles with ticker symbols and covers NSE/BSE listings,
# which most US-centric news APIs do not.
# Obtain: https://www.marketaux.com/  (free tier: 100 requests/day)
MARKETAUX_API_KEY=

# --- Macro data ------------------------------------------------------------
# Required for: macro/current-affairs signals (policy rates, CPI, yields).
# Obtain: https://fred.stlouisfed.org/docs/api/api_key.html  (free, no quota)
FRED_API_KEY=

# --- LLM (optional) --------------------------------------------------------
# Optional. Used only to generate narrative event-impact explanations.
# Without it, impact analysis still runs from the rule-based relevance engine;
# only the prose summary is omitted.
# Obtain: https://aistudio.google.com/apikey  (free tier available)
GEMINI_API_KEY=

# --- Application -----------------------------------------------------------
STOCKINTEL_ENV=development
LOG_LEVEL=INFO

# Cache root (relative paths resolve against the backend package directory)
CACHE_DIR=.cache

# Cache TTLs in seconds. Different data ages at different rates.
CACHE_TTL_INTRADAY=60          # live/delayed quote
CACHE_TTL_DAILY_BARS=3600      # EOD OHLCV history
CACHE_TTL_NEWS=900             # news listings (15 min)
CACHE_TTL_FUNDAMENTALS=86400   # fundamentals (1 day)
CACHE_TTL_SENTIMENT=604800     # FinBERT output, keyed by content hash (7 days)

# CORS origin for the Next.js dev server
FRONTEND_ORIGIN=http://localhost:3000
