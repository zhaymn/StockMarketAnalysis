# Secrets — never commit
backend/.env

# Isolated backend virtualenv
backend/.venv/

# Caches (regenerated on demand)
backend/.cache/
backend/.pytest_cache/
__pycache__/
*.pyc

# Trained model weights: large and regenerable, so not tracked.
# The *.json experiment reports ARE tracked -- they are the evidence behind
# every result quoted in the README, and a reader should be able to audit those
# numbers without re-running hours of walk-forward validation.
backend/.artifacts/*
!backend/.artifacts/*.json

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
